# Xcode — user & UI state
.DS_Store
**/.DS_Store
xcuserdata/
*.xccheckout
*.xcscmblueprint
*.xcuserstate
*.moved-aside
**/build/*

# Xcode project cruft (legacy editors)
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# Do NOT use `*.xcworkspace` here — the CocoaPods/app workspace (`*.xcworkspace`) must stay trackable.

# Local Xcode / SPM derived data mistakenly placed inside the repo
.derived*/
DerivedData/
*.xcresult

# Swift Package Manager
.build/
Packages/
Package.resolved
.swiftpm/
**/.swiftpm/

# SPM / Xcode caches under ad-hoc derived folders
**/SourcePackages/

# Cocoapods
Pods/

# IDEA / tooling
.idea
.prettierignore
.prettierrc
.code-workspace

# Deliverables / archives at repo root
*.zip
*.ipa
*.dSYM.zip

# Local Xcode `build/` output (often at repo root)
build/

# Optional: SPM disabled source copies
*.swift.disabled
